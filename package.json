{
  "name": "fp-conv",
  "version": "1.0.0",
  "description": "Interactive tool for converting and visualizing floating-point numbers across standard and custom formats. Convert between FP32, FP16, BF16, TF32, FP8, etc. while inspecting binary representations and precision loss.",
  "main": "lib/floating-point.js",
  "exports": {
    ".": "./lib/floating-point.js"
  },
  "files": [
    "lib/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sw23/fp-conv.git"
  },
  "keywords": [
    "floating-point",
    "fp32",
    "fp16",
    "bf16",
    "tf32",
    "fp8",
    "ieee-754"
  ],
  "author": "Spencer Williams",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/sw23/fp-conv/issues"
  },
  "homepage": "https://sw23.github.io/fp-conv/",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jest": "^30.3.0"
  }
}
